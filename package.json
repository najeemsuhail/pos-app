{
  "name": "Chewbiecafe-pos",
  "version": "1.5.0",
  "private": true,
  "description": "Offline desktop Chewbiecafe POS application",
  "author": "Hope",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "rebrand": "node scripts/rebrand.js",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run start --workspace frontend",
    "dev:desktop": "cross-env BROWSER=none concurrently \"cross-env DESKTOP_USE_SQLITE=true npm run dev:backend\" \"npm run dev:frontend\" \"npm run electron:dev\"",
    "electron:dev": "wait-on tcp:5000 http://localhost:3000 && cross-env ELECTRON_DEV=true ELECTRON_START_URL=http://localhost:3000 electron .",
    "desktop": "cross-env DESKTOP_USE_SQLITE=true npm run build && electron .",
    "dist:desktop": "cross-env DESKTOP_USE_SQLITE=true npm run build && electron-builder",
    "build": "npm run build --workspace frontend && node scripts/prepare-vercel-static.js",
    "start": "npm run start --workspace backend"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.40.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-machine-id": "^1.1.12",
    "uuid": "^9.0.1"
  },
  "main": "electron/main.js",
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "electron-builder": "^24.13.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.Chewbiecafe.pos.app",
    "productName": "Chewbiecafe POS",
    "icon": "assets/icon.png",
    "files": [
      "assets/**/*",
      "backend/**/*",
      "electron/**/*",
      "frontend/package.json",
      "index.js",
      "package.json",
      "public/**/*"
    ],
    "asarUnpack": [
      "backend/src/generated/prisma/**/*",
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}