// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int      @id @default(autoincrement())
  name                   String   @unique
  role                   String
  password               String
  featureAccessOverrides String?  @map("feature_access_overrides")
  createdAt              DateTime @default(now()) @map("created_at")

  attendances            StaffAttendance[]

  @@map("users")
}

model StaffAttendance {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  attendanceDate String   @map("attendance_date")
  status         String
  checkIn        String?  @map("check_in")
  checkOut       String?  @map("check_out")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, attendanceDate])
  @@index([attendanceDate])
  @@map("staff_attendance")
}

model Category {
  id        Int     @id @default(autoincrement())
  name      String
  isDeleted Boolean @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  
  menuItems MenuItem[]

  @@map("categories")
}

model MenuItem {
  id        Int     @id @default(autoincrement())
  name      String
  price     Decimal
  categoryId Int     @map("category_id")
  isAvailable Boolean @default(true) @map("is_available")
  imageUrl  String? @map("image_url")
  isDeleted Boolean @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  
  category  Category @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@index([categoryId])
  @@map("menu_items")
}

model Order {
  id           Int     @id @default(autoincrement())
  billNumber   String  @unique @map("bill_number")
  status       String  @default("pending")
  paymentStatus String @default("unpaid") @map("payment_status")
  customerName String? @map("customer_name")
  customerPhone String? @map("customer_phone")
  tableId      Int?    @map("table_id")
  orderType    String  @default("dine_in") @map("order_type")
  subtotal     Decimal @default(0)
  discountAmount Decimal @default(0) @map("discount_amount")
  taxAmount    Decimal @default(0) @map("tax_amount")
  finalAmount  Decimal @default(0) @map("final_amount")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  items    OrderItem[]
  payments Payment[]
  kotTickets KotTicket[]

  @@index([status])
  @@index([orderType])
  @@index([createdAt])
  @@map("orders")
}

model KotTicket {
  id        Int      @id @default(autoincrement())
  orderId   Int      @map("order_id")
  kotNumber String   @unique @map("kot_number")
  status    String   @default("printed")
  printedAt DateTime? @map("printed_at")
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items KotItem[]

  @@index([orderId])
  @@index([status])
  @@map("kot_tickets")
}

model KotItem {
  id          Int      @id @default(autoincrement())
  kotTicketId Int      @map("kot_ticket_id")
  orderItemId Int?     @map("order_item_id")
  menuItemId  Int      @map("menu_item_id")
  name        String
  quantity    Int
  note        String?
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")

  ticket KotTicket @relation(fields: [kotTicketId], references: [id], onDelete: Cascade)

  @@index([kotTicketId])
  @@index([orderItemId])
  @@map("kot_items")
}

model BillSequence {
  id           Int      @id @default(autoincrement())
  businessDate String   @unique @map("business_date")
  lastNumber   Int      @default(0) @map("last_number")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("bill_sequences")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  menuItemId Int    @map("menu_item_id")
  name      String
  price     Decimal
  quantity  Int
  createdAt DateTime @default(now()) @map("created_at")
  
  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Payment {
  id          Int     @id @default(autoincrement())
  orderId     Int     @map("order_id")
  method      String
  source      String  @default("Direct")
  status      String  @default("settled")
  amount      Decimal
  settledAmount Decimal @default(0) @map("settled_amount")
  referenceId String?  @map("reference_id")
  settledAt   DateTime? @map("settled_at")
  createdAt   DateTime @default(now()) @map("created_at")
  
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payments")
}

model Expense {
  id          Int      @id @default(autoincrement())
  expenseDate DateTime @map("expense_date")
  category    String
  note        String
  amount      Decimal
  paymentMethod String @map("payment_method")
  reference   String?  @map("reference")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([expenseDate])
  @@map("expenses")
}

model Supplier {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  phone       String?
  email       String?
  address     String?
  notes       String?
  createdAt   DateTime   @default(now()) @map("created_at")

  purchases   Purchase[]

  @@map("suppliers")
}

model Purchase {
  id             Int            @id @default(autoincrement())
  supplierId     Int            @map("supplier_id")
  purchaseDate   DateTime       @map("purchase_date")
  invoiceNumber  String?        @map("invoice_number")
  paymentStatus  String         @default("unpaid") @map("payment_status")
  subtotal       Decimal        @default(0)
  taxAmount      Decimal        @default(0) @map("tax_amount")
  discountAmount Decimal        @default(0) @map("discount_amount")
  totalAmount    Decimal        @default(0) @map("total_amount")
  paidAmount     Decimal        @default(0) @map("paid_amount")
  note           String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  supplier Supplier       @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]

  @@index([supplierId])
  @@index([purchaseDate])
  @@index([paymentStatus])
  @@map("purchases")
}

model PurchaseItem {
  id          Int      @id @default(autoincrement())
  purchaseId  Int      @map("purchase_id")
  itemName    String   @map("item_name")
  quantity    Decimal
  unit        String?
  unitPrice   Decimal  @map("unit_price")
  totalPrice  Decimal  @map("total_price")
  createdAt   DateTime @default(now()) @map("created_at")

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@map("purchase_items")
}
